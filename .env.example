# Public origin for canonical URLs, og:url, og:image, and JSON-LD (no trailing slash).
# On Netlify, if this is empty the build uses the deploy URL from the platform (https://…).
# You can still set this to your primary domain. Omitting https:// is OK (it is added automatically):
#   VITE_SITE_URL=https://perfectseo.netlify.app
#   VITE_SITE_URL=perfectseo.netlify.app
VITE_SITE_URL=
